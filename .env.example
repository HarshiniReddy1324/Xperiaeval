# Vercel (frontend) — set in Project → Settings → Environment Variables
VITE_API_BASE=https://YOUR-SERVICE.onrender.com

# Render (API) — set in Render dashboard → Environment
JWT_SECRET=
PUBLIC_APP_URL=https://YOUR-APP.vercel.app
ALLOWED_ORIGINS=https://YOUR-APP.vercel.app,https://your-custom-domain.com
GROQ_API_KEY=
NODE_ENV=production
DATA_DIR=/var/data/data
UPLOADS_DIR=/var/data/uploads

# Local split-stack test (optional .env.local for Vite)
# VITE_API_BASE=http://localhost:3001
