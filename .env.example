# Vercel (frontend) — Project → Settings → Environment Variables
VITE_API_BASE=https://YOUR-SERVICE.onrender.com

# Oracle VM (API) — Docker -e flags or scripts/oracle-deploy.sh
JWT_SECRET=
PUBLIC_APP_URL=https://YOUR-APP.vercel.app
ALLOWED_ORIGINS=https://YOUR-APP.vercel.app
GROQ_API_KEY=
NODE_ENV=production
DATA_DIR=/var/data/data
UPLOADS_DIR=/var/data/uploads

# Local dev — leave VITE_API_BASE unset (Vite proxies /api to :3001)

# Inbound sales / contact notifications (logged to email_outbox when EMAIL_API_KEY is unset)
CONTACT_INBOX_EMAIL=pharshinireddy13@gmail.com
